OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1
OPENAI_BASE_URL=https://api.openai.com/v1

# Auth
JWT_SECRET=change_me

# Data store
# - json (default): persists to backend/db.local.json
# - postgres: persists to PostgreSQL in app_state table
DATA_STORE=json

# Optional: override JSON DB location (default: backend/db.local.json)
# DB_JSON_PATH=C:\\path\\to\\db.local.json

# PostgreSQL (required for DATA_STORE=postgres and scripts/seed.js)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=techmarket
DB_USER=postgres
DB_PASSWORD=postgres

