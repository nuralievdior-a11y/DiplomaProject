GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_TEMPERATURE=0.35
GEMINI_MAX_OUTPUT_TOKENS=700

# Auth
JWT_SECRET=change_me

# Data store
# - json (default): persists to backend/db.local.json
# - postgres: persists to PostgreSQL in app_state table
DATA_STORE=json

# Optional: override JSON DB location (default: backend/db.local.json)
# DB_JSON_PATH=C:\\path\\to\\db.local.json

# PostgreSQL (required for DATA_STORE=postgres and scripts/seed.js)

# Option A (recommended on Render): single URL
# DATABASE_URL=postgres://user:password@host:5432/dbname
# DB_SSL=true

# Option B: separate params (local dev)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=techmarket
DB_USER=postgres
DB_PASSWORD=postgres

