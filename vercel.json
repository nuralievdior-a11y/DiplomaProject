{
  "version": 2,
  "builds": [
    {
      "src": "techmarket/frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist/DiplomaProject" }
    },
    {
      "src": "techmarket/dashboard/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist/DiplomaProject/dashboard" }
    }
  ],
  "routes": [
    { "src": "^/$", "status": 308, "headers": { "Location": "/DiplomaProject/" } },
    { "src": "^/DiplomaProject$", "status": 308, "headers": { "Location": "/DiplomaProject/" } },
    { "src": "^/DiplomaProject/dashboard$", "status": 308, "headers": { "Location": "/DiplomaProject/dashboard/" } },
    { "handle": "filesystem" },
    { "src": "^/DiplomaProject/dashboard/(.*)$", "dest": "/DiplomaProject/dashboard/index.html" },
    { "src": "^/DiplomaProject/(.*)$", "dest": "/DiplomaProject/index.html" }
  ]
}
